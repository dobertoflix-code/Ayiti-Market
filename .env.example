# Kopye fichye sa a → renome l ".env" → ranpli vrè valè yo.
# JANM komèt vrè ".env" la nan Git (li deja nan .gitignore si genyen).

# URL ak kle anonim Supabase ou (Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY

# URL piblik final sit la (itilize pou sitemap.xml, og:url, canonical)
SITE_URL=https://ayitimarket.com

# Pò lokal pou devlopman (Render/Railway konfigire sa otomatikman)
PORT=3000
